# Compose
COMPOSE_PROJECT_NAME=dsml-kit

# Runtime mode
DSML_MODE=image # `image` uses published image, `dev` builds locally.

# Hardware
GPU_ENABLED=false # `false`, `true`
GPU_DEVICES=all # `all`, `none`, or comma-separated GPU IDs
NVIDIA_DRIVER_CAPABILITIES=all # `all`, `compute,utility`, `compute,utility,video`

# Published image
IMAGE_NAME=ghcr.io/mihneateodorstoica/dsml-kit
DSML_TAG=latest
PULL_POLICY=missing # `always`, `missing`, `never`
RESTART_POLICY=unless-stopped # `no`, `always`, `on-failure`, `unless-stopped`

# Network
JUPYTER_BIND_ADDRESS=127.0.0.1
JUPYTER_PORT=8888
JUPYTER_BASE_URL=/

# Workspace
WORKSPACE_DIR=./workspace
JUPYTER_ROOT_DIR=/home/jovyan/work
HOST_UID=1000 # Host user ID; `make` exports current UID automatically.
HOST_GID=1000 # Host group ID; `make` exports current GID automatically.

# Logging
JUPYTER_APP_LOG_LEVEL=WARN # `DEBUG`, `INFO`, `WARN`, `ERROR`, `CRITICAL`
JUPYTER_SERVER_LOG_LEVEL=WARN # `DEBUG`, `INFO`, `WARN`, `ERROR`, `CRITICAL`

# Advanced Jupyter args
JUPYTER_EXTRA_ARGS=

# Auth
JUPYTER_TOKEN=replace-me # `make env` generates one automatically.
